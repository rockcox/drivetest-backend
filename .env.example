# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Resend (Email)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourdomain.ca

# 2captcha
CAPTCHA_API_KEY=xxx

# Proxy (BrightData / Oxylabs)
PROXY_HOST=brd.superproxy.io
PROXY_PORT=22225
PROXY_USER=your-proxy-user
PROXY_PASS=your-proxy-pass

# App
PORT=3001
NODE_ENV=development
APP_URL=https://yourdomain.ca
ENCRYPTION_KEY=32-char-random-hex-string-here!!

# Worker config
MAX_CONCURRENT_SESSIONS=20
SCAN_INTERVAL_MIN_MINUTES=4
SCAN_INTERVAL_MAX_MINUTES=8
SLOT_HOLD_HOURS=2
